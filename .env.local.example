# Amap (高德地图) — https://console.amap.com
# JS API key: used for the interactive map on the frontend
NEXT_PUBLIC_AMAP_JS_KEY=your_amap_js_api_key_here

# REST API key: used for server-side geocoding and place search
NEXT_PUBLIC_AMAP_REST_KEY=your_amap_rest_api_key_here

# Convex (optional — not yet active, reserved for future database migration)
NEXT_PUBLIC_CONVEX_URL=
